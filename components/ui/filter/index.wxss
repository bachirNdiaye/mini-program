.filter-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 35px;
  padding: 4px 10px;
  margin-bottom: 10px;
}

.search {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.icon {
  width: 20px;
  height: 20px;
  margin-right: 12px;
  opacity: 0.6;
}

.search-input {
  flex: 1;
  border: none;
  background: transparent;
  font-size: 12px;
  color: #333;
  outline: none;
}

.search-input::placeholder {
  color: #999;
  font-weight: 400;
}

.filter-btn {
  width: 40px;
  height: 40px;
  display: flex;
  justify-content: center;
  align-items: center;
  background: transparent;
  border: none;
  border-radius: 50%;
  margin-left: 8px;
  cursor: pointer;
}

.filter-btn .icon {
  margin-right: 0;
}
