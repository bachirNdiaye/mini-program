.card {
  display: flex;
  flex-direction: row;
  border-radius: 12px;
  background-color: #fff;
  padding: 10px;
  margin: 10px 0;
}

.card-img {
  width: 220rpx;
  height: 220rpx;
  border-radius: 12px;
  object-fit: contain;
}

.card-body {
  flex: 1;
  margin-left: 12px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.category {
  font-size: 24rpx;
  color: #a29e9e92;
  font-weight: 600;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  margin: 6rpx 0;
  line-height: 1.8;
}

.meta {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #777;
}

.avatar {
  width: 45rpx;
  height: 45rpx;
  width: 45rpx;
  height: 45rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.dot {
  margin: 0 15rpx;
  color: #a29e9e92;
}
.text-sm {
  font-size: 25rpx;
  color: #a29e9e92;
  font-weight: 600;
}
