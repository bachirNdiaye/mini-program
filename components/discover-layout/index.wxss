.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.appbar {
  height: 50px;
  display: flex;
  align-items: center;
  padding: 0 12px;
  border-bottom: 1px solid #eee;
}

.header {
  padding: 10px 12px;
}

.filter {
  padding: 0px 10px;
}

.pills {
  padding: 6px 0;
}

.list {
  flex: 1;
  overflow-y: auto;
}
