.slider {
  height: 420rpx;
  margin-bottom: 50rpx;
}

.slide {
  width: 95%;
  margin: 0 auto;
  height: 100%;
  border-radius: 24rpx;
  overflow: hidden;
  position: relative;
  background: #f2f2f2;
  
}

.bg {
  width: 100%;
  height: 100%;
  object-fit: cover;
 
}

.category {
    
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  background-color: #007aff;
  color: white;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  z-index: 10;
}

.overlay {
  position: absolute;
  bottom: 0;
  padding: 30rpx;
  width: 100%;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.6), transparent);
  color: white;
  
}

.info {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  margin-bottom: 10rpx;
  
}

.title {
    width: 70%;
  font-size: 30rpx;
  font-weight: bold;
}

.dot {
  width: 10rpx;
  height: 10rpx;
  background-color: #ffffff;
  border-radius: 50%;
  margin-right: 15rpx;
  margin-left: 15rpx;
}
.verified {
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  display: inline-block;
  
  margin-left: 15rpx;
}