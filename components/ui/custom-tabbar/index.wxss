.custom-tabbar {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  align-items: center;
  background-color: #ffffff;
  border-top: 1px solid #e0e0e0;
  padding: 10px 0;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  padding-bottom:25px;
  padding-top:12px;
  padding-left: 16px;
  padding-right: 16px;
}

.custom-tabbar-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 8px;
  cursor: pointer;
  transition: all 0.3s ease;
  gap: 6px;
  border-radius: 20px;
  margin: 0 4px;
}

.custom-tabbar-item:active {
  opacity: 0.7;
}

.custom-tabbar-item.active {
  transform: scale(1.05);
  background-color: #007aff;
  box-shadow: 0 2px 8px rgba(0, 122, 255, 0.3);
}

.custom-tabbar-item.active .custom-tabbar-item-icon {
  filter: brightness(0) invert(1);
}

.custom-tabbar-item.active text {
  color: #ffffff;
  font-weight: 600;
  animation: fadeIn 0.3s ease;
}

.custom-tabbar-item-icon {
  width: 24px;
  height: 24px;
  transition: all 0.3s ease;
}

.custom-tabbar-item text {
  font-size: 12px;
  color: #666666;
  text-align: center;
  transition: all 0.3s ease;
  white-space: nowrap;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateX(-10px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}
