/* Conteneur principal qui commence au milieu de la page */
.scrollable-container {
  position: relative;
  top: -25px;
  left: 0;
  right: 0;
  bottom: 0;
  background: white;
  border-radius: 25px 25px 0 0;
  box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.1);
  z-index: 9999;
  overflow-y: scroll;
  -webkit-overflow-scrolling: touch;
  min-height: 50vh;
  transition: position 0.3s ease, height 0.3s ease, min-height 0.3s ease;
}

/* Bottom-sheet en position absolue quand scrollé */
.scrollable-container.scrolled {
  position: absolute;
  top: 0;
  border-radius: 0;
  height: 100vh;
  min-height: 100vh;
}

/* Contenu scrollable */
.scrollable-content {
  padding: 20px;

  /* Pour un scroll fluide sur iOS */
}

/* Bloc de texte unique */
.text-block-header {
  padding: 10px 16px 0 16px;
  display: flex;
  align-items: center;
  /*justify-content: space-between;*/
}

.text-block-content {
  padding: 20px 16px 20px 16px;
}

/* Titre du texte */
.text-block-title {
  display: block;
  font-size: 24px;
  font-weight: 900;
  color: #000;
  line-height: 1.3;

}

/* Logo du header */
.header-logo {
  width: 40px;
  height: 40px;
  margin-right: 10px;
  border-radius: 50%;
}
.header-badge {
  width: 22px;
  height: 22px;
  margin-left: 8px;
}

/* Contenu du texte */
.text-content {
  display: block;
  font-size: 16px;
  color: #000;
  line-height: 1.6;
  text-align: justify;
  white-space: pre-wrap;
}

/* Animation d'entrée pour le bloc de texte */
@keyframes slideInUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.text-block {
  animation: slideInUp 0.4s ease forwards;
}

/* Responsive design */
@media (max-width: 400px) {
  .scrollable-content {
    padding: 16px;
  }

  .text-block {
    padding: 16px;
  }

  .text-title {
    font-size: 18px;
    margin-bottom: 12px;
  }

  .text-content {
    font-size: 14px;
  }
}