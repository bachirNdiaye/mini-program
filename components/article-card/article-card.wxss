.card {
  display: flex;
  flex-direction: row;
  border-radius: 12px;
  background-color: #fff;
  padding: 10px;
  box-shadow: 0 2px 6px rgba(0,0,0,0.1);
  margin: 10px 0;
}

.card-img {
  width: 220rpx;
  height: 220rpx;
  border-radius: 8px;
  object-fit: contain;
}

.card-body {
  flex: 1;
  margin-left: 12px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.category {
  font-size: 24rpx;
  color: gray;
}

.title {
  font-size: 28rpx;
  font-weight: bold;
  margin: 6rpx 0;
  line-height: 1.4;
}

.meta {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #777;
}

.avatar {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.dot {
  margin: 0 6rpx;
}
