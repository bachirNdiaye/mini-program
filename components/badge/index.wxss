.badge-container {
  display: inline-block;
  padding: 4px 16px;
  border-radius: 20px;
  margin: 4px;
  background-color: #f0f0f0;
}

.badge-container.active {
  background-color: #007aff; /* bleu */
}

.badge-text {
  font-size: 12px;
  color: #333;
}

.badge-container.active .badge-text {
  color: white;
}
