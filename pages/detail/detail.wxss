/* Container du header avec image de background */
.header-container {
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  border-radius: 12px 12px 0 0;
  margin: 0 -16px;
  padding: 20px 16px 10px 16px;
  position: relative;
  height: 53vh;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: flex-end;
  z-index: 1;
  transition: height 0.3s ease, position 0.3s ease;
  overflow: hidden;
}

/* Header en position fixed quand scrollé */
.header-container.fixed {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 9998;
}

/* Header expandable */
.header-container.expanded {
  height: 80vh;
}

/* Overlay pour améliorer la lisibilité du texte */
.header-container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 12px 12px 0 0;
  z-index: 1;
}

/* Layer avec dégradé transparent au centre */
.header-container::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(
    to bottom,
    rgba(0, 0, 0, 0.9) 0%,
    transparent 20%,
    transparent 60%,
    rgba(0, 0, 0, 0.9) 100%
  );
  border-radius: 12px 12px 0 0;
  z-index: 1;
}

/* Titre du header */
.header-title {
  position: relative;
  z-index: 2;
  padding: 0 16px;
  margin-bottom: 30px;
  transition: transform 0.3s ease;
}

.header-container.expanded .header-title {
  transform: translateY(-20px);
}

.header-title text {
  font-size: 24px;
  font-weight: 600;
  color: white;
}

.header-tag text {
  font-size: 12px;
  font-weight: 300;
  color: white;
}

.header-category {
  background-color: #007aff;
  padding: 4px 16px;
  margin-left: 16px;
  margin-bottom: 8px;
  border-radius: 12px;
  display: inline-block;
  line-height: 1;
  align-self: start;
  text-align: center;
  min-width: fit-content;
  transition: transform 0.3s ease;
}

.header-container.expanded .header-category {
  transform: translateY(-20px);
}

.header-category text {
  font-size: 14px;
  color: white;
  display: block;
  text-align: center;
}
