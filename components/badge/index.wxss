.badge-container {
  display: inline-flex;   /* 👈 flex au lieu de inline-block */
  align-items: center;    /* 👈 centre verticalement */
  justify-content: center;/* 👈 centre horizontalement */
  padding: 10px 16px;
  border-radius: 20px;
  margin: 4px;
  background-color: #f0f0f0;
}

.badge-container.active {
  background-color: #007aff;  
}

.badge-text {
  font-size: 14px;
  color: grey;
}

.badge-container.active .badge-text {
  color: white;
}
